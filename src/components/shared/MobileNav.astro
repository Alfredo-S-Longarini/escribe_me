---
const pathname = Astro.url.pathname
---

<nav class="mobile-nav">
  <a href="/app" class={`mobile-nav-item ${pathname === '/app' ? 'active' : ''}`}>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
      <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
    </svg>
    <span>Biblioteca</span>
  </a>

  <a href="/app/nuevo" class={`mobile-nav-item ${pathname === '/app/nuevo' ? 'active' : ''}`}>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    <span>Nuevo</span>
  </a>

  <a href="/app/perfil" class={`mobile-nav-item ${pathname === '/app/perfil' ? 'active' : ''}`}>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
    </svg>
    <span>Perfil</span>
  </a>
</nav>

<style>
  .mobile-nav {
    display: none;
    position: sticky;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--bg-surface);
    border-top: 1px solid var(--border);
    padding: 0.5rem 0 calc(0.5rem + env(safe-area-inset-bottom));
  }

  @media (max-width: 767px) {
    .mobile-nav { display: flex; }
  }

  .mobile-nav-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 0;
    text-decoration: none;
    color: var(--text-faint);
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.05em;
    transition: color 0.15s;
  }

  .mobile-nav-item.active {
    color: var(--accent);
  }

  .mobile-nav-item:not(.active):hover {
    color: var(--text-muted);
  }
</style>
