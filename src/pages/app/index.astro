---
import AppLayout from '../../layouts/AppLayout.astro'
import BookGrid from '../../components/library/BookGrid'
---

<AppLayout title="Mi biblioteca — Escribe.me">
  <div class="px-8 py-8 lg:px-12">
    <div class="flex items-baseline justify-between mb-8">
      <h1 class="font-serif font-light text-2xl" style="color: var(--text)">Mi biblioteca</h1>
      <a
        href="/app/nuevo"
        class="font-sans text-xs font-medium tracking-widest uppercase px-5 py-2.5 transition-colors"
        style="background: var(--accent); color: var(--bg);"
        onmouseover="this.style.opacity='0.85'"
        onmouseout="this.style.opacity='1'"
      >
        + Nuevo escrito
      </a>
    </div>
    <BookGrid client:load />
  </div>
</AppLayout>
